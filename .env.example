PORT=5000
MONGO_URI=mongodb://mongodb:27017/multimedia_db?replicaSet=rs0
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
RABBITMQ_URL=amqp://rabbitmq
SESSION_SECRET="change_this_to_something_secure"

# Tailscale / Remote Access Configuration
# Replace 100.x.y.z with your Raspberry Pi's Tailscale IP
FRONTEND_URL=http://100.x.y.z:3000
VITE_API_URL=http://100.x.y.z:5000

# Google OAuth (Must match the Authorized redirect URIs in Google Console)
GOOGLE_CLIENT_ID=your_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_secret
GOOGLE_CALLBACK_URL=http://100.x.y.z:5000/auth/google/callback
